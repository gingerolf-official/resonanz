{
  "name": "Resonanz",
  "short_name": "Resonanz",
  "description": "GFK-gestützte Nachrichtenverarbeitung",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#F2EDE5",
  "theme_color": "#2A4740",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "./?share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", ".opus", ".mp3", ".m4a", ".wav", ".ogg", ".aac"]
        }
      ]
    }
  }
}
